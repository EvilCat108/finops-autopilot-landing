---
import { site } from "../site.config";
const year = new Date().getFullYear();
---

<footer class="border-t border-border/60 py-12">
  <div class="container-x flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
    <div class="flex items-center gap-2 text-sm text-muted">
      <span class="inline-block h-2 w-2 rounded-full bg-accent" aria-hidden="true"></span>
      <span>© {year} {site.name}</span>
    </div>

    <nav aria-label="Footer" class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-muted">
      <a href={`mailto:${site.email}`} class="hover:text-text transition-colors">{site.email}</a>
      <span class="hidden sm:inline" aria-hidden="true">·</span>
      <span>AWS only. Multi-cloud is not on the roadmap.</span>
    </nav>
  </div>
</footer>
