---
const pains = [
  {
    title: "Wasted spend is invisible.",
    body: "Cost dashboards show totals, not the EC2 instance no one SSH'd into for 90 days.",
    icon: "eye",
  },
  {
    title: "Cleanup is manual and political.",
    body: "Tagging initiatives take quarters. Nobody owns \"delete that EBS volume.\"",
    icon: "wrench",
  },
  {
    title: "Rightsizing is a one-off project.",
    body: "The moment the engagement ends, drift returns. Waste compounds every month.",
    icon: "clock",
  },
  {
    title: "Multi-account sprawl.",
    body: "Orphaned LBs in staging-archive-2022 are still billed. Old AMIs. Forgotten snapshots.",
    icon: "stack",
  },
];
---

<section id="pains" class="section border-t border-border/60">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center reveal">
      <h2 class="font-display text-3xl font-semibold tracking-tight text-text sm:text-4xl">
        The AWS bill hides waste, your team can't keep up.
      </h2>
      <p class="mt-4 text-muted">
        Every AWS account drifts toward waste. The tools to find it are noisy, the
        fixes are slow, and ownership never sticks.
      </p>
    </div>

    <ul class="mt-14 grid gap-5 sm:grid-cols-2">
      {
        pains.map((p, i) => (
          <li
            class="card-hover reveal"
            style={`transition-delay: ${i * 60}ms`}
          >
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-input bg-accent-soft text-accent">
              {p.icon === "eye" && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              )}
              {p.icon === "wrench" && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M14.7 6.3a4 4 0 0 0 5 5l-9 9-5-5 9-9Z" />
                </svg>
              )}
              {p.icon === "clock" && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" />
                  <path d="M12 7v5l3 2" />
                </svg>
              )}
              {p.icon === "stack" && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 3 2 8l10 5 10-5-10-5Z" />
                  <path d="M2 14l10 5 10-5M2 18l10 5 10-5" />
                </svg>
              )}
            </div>
            <h3 class="font-display text-lg font-semibold text-text">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{p.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
