---
const roleOptions = [
  { value: "", label: "Select your role…" },
  { value: "devops", label: "DevOps / SRE" },
  { value: "platform", label: "Platform Engineering" },
  { value: "finops", label: "FinOps" },
  { value: "leadership", label: "CTO / VP Engineering" },
  { value: "other", label: "Other" },
];

const spendOptions = [
  { value: "", label: "Select monthly AWS spend…" },
  { value: "lt5k", label: "Under $5k" },
  { value: "5to25k", label: "$5k – $25k" },
  { value: "25to100k", label: "$25k – $100k" },
  { value: "100to500k", label: "$100k – $500k" },
  { value: "gt500k", label: "$500k+" },
];
---

<section id="signup" class="section border-t border-border/60">
  <div class="container-x">
    <div class="mx-auto max-w-xl">
      <div class="text-center reveal">
        <h2 class="font-display text-3xl font-semibold tracking-tight text-text sm:text-4xl">
          Join early access
        </h2>
        <p class="mt-3 text-muted">
          We're onboarding ~50 teams. Tell us a bit about you and we'll be in
          touch within 2 business days.
        </p>
      </div>

      <form
        id="early-access-form"
        name="early-access"
        method="POST"
        action="/submit"
        class="card mt-10 reveal"
        style="transition-delay: 80ms"
      >
        <!-- Honeypot for spam bots -->
        <p class="hidden" aria-hidden="true">
          <label>
            Don't fill this out:
            <input name="bot-field" tabindex="-1" autocomplete="off" />
          </label>
        </p>

        <div>
          <label for="email" class="label">Work email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="you@company.com"
            class="input"
          />
        </div>

        <div class="mt-5">
          <label for="role" class="label">Role</label>
          <select id="role" name="role" required class="input">
            {roleOptions.map((o) => <option value={o.value}>{o.label}</option>)}
          </select>
        </div>

        <div class="mt-5">
          <label for="spend" class="label">AWS monthly spend</label>
          <select id="spend" name="spend" required class="input">
            {spendOptions.map((o) => <option value={o.value}>{o.label}</option>)}
          </select>
        </div>

        <button
          type="submit"
          class="btn-primary mt-6 w-full justify-center px-5 py-3 text-base"
        >
          <span data-label>Request early access</span>
          <svg
            data-spinner
            class="h-4 w-4 animate-spin hidden"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25" />
            <path d="M22 12a10 10 0 0 1-10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
          </svg>
        </button>

        <p data-error class="mt-4 hidden text-center text-sm text-red-600"></p>

        <p class="mt-4 text-center text-xs text-muted">
          We'll only use your email to contact you about early access.
          No newsletter, no marketing list.
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  // Progressive enhancement: AJAX submit with graceful no-JS fallback
  // (the form's action="/submit" still works without JS via 303 redirect).
  (function () {
    const form = document.getElementById("early-access-form") as HTMLFormElement | null;
    const button = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
    const label = form?.querySelector<HTMLElement>("[data-label]");
    const spinner = form?.querySelector<HTMLElement>("[data-spinner]");
    const error = form?.querySelector<HTMLElement>("[data-error]");
    if (!form || !button || !label || !spinner || !error) return;

    form.addEventListener("submit", async function (e) {
      // Let the browser's native validation run first
      if (!form.reportValidity()) return;

      e.preventDefault();
      error.classList.add("hidden");
      error.textContent = "";

      const originalLabel = label.textContent ?? "";
      button.disabled = true;
      label.textContent = "Submitting…";
      spinner.classList.remove("hidden");

      const reset = (): void => {
        button.disabled = false;
        label.textContent = originalLabel;
        spinner.classList.add("hidden");
      };

      try {
        const formData = new FormData(form);
        const res = await fetch(form.action, {
          method: form.method,
          body: formData,
          headers: { Accept: "application/json" },
        });

        if (res.redirected) {
          window.location.href = res.url;
          return;
        }
        if (res.ok) {
          // Function may return 200 with a body in some edge cases — treat as success
          window.location.href = "/?submitted=true#signup";
          return;
        }

        const msg = await res.text().catch(() => "Submission failed");
        error.textContent = msg || "Submission failed. Please try again.";
        error.classList.remove("hidden");
        reset();
      } catch {
        error.textContent = "Network error. Please try again.";
        error.classList.remove("hidden");
        reset();
      }
    });
  })();
</script>
